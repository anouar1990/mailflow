# SUPABASE (Required for Database and Server Auth)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# AWS SES (Required for actual email delivery)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# VERCEL CRON (Optional locally, Vercel will auto-generate this in production)
CRON_SECRET=your_custom_cron_secret_for_local_testing
