# Supabase Configuration
# Get these from your Supabase dashboard: https://app.supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# AWS SES Configuration
# Get these from AWS IAM Console: https://console.aws.amazon.com/iam
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# SES Configuration Set (for tracking opens/clicks via SNS)
# Create in AWS SES Console > Configuration Sets
SES_CONFIGURATION_SET_NAME=mailflow-tracking

# NextAuth (optional - for user authentication)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-key
NEXTAUTH_URL=http://localhost:3000

# Application Settings
# Your verified SES identity (email or domain)
SES_FROM_EMAIL=noreply@yourdomain.com
SES_FROM_NAME=MailFlow
